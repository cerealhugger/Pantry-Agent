BROWSERBASE_API_KEY=
# Demo-friendly default: verify the first four major ingredients in parallel.
NUTRITION_MAX_INGREDIENTS=4
# Optional. Uses Browserbase Model Gateway; no separate model-provider key is required.
STAGEHAND_MODEL=google/gemini-3-flash-preview

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Recommended for server-side nutrition verification writes when RLS is enabled.
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
